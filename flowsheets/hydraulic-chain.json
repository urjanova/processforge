{
  "metadata": {
    "name": "Hydraulic Chain Example",
    "description": "A two-pump, one-valve, one-strainer steady-state hydraulic system.",
    "version": "2.0"
  },
  "streams": {
    "feed": {
      "T": 298.15,
      "P": 101325,
      "z": {
        "Water": 0.8,
        "Toluene": 0.2
      },
      "flowrate": 1.0
    }
  },
  "units": {
    "pump_1": {
      "type": "Pump",
      "in": "feed",
      "out": "after_pump_1",
      "deltaP": 200000.0,
      "efficiency": 0.75
    },
    "pipe_1": {
      "type": "Pipes",
      "in": "after_pump_1",
      "out": "after_pipe_1",
      "delta_p": 1000.0,
      "diameter": 0.05
    },
    "valve_1": {
      "type": "Valve",
      "in": "after_pipe_1",
      "out": "after_valve_1",
      "pressure_ratio": 0.5
    },
    "pipe_2": {
      "type": "Pipes",
      "in": "after_valve_1",
      "out": "after_pipe_2",
      "delta_p": 1000.0,
      "diameter": 0.08
    },
    "strainer_1": {
      "type": "Strainer",
      "in": "after_pipe_2",
      "out": "after_strainer_1",
      "deltaP": 5000.0
    },
    "pipe_3": {
      "type": "Pipes",
      "in": "after_strainer_1",
      "out": "after_pipe_3",
      "delta_p": 1000.0,
      "diameter": 0.1
    },
    "pump_2": {
      "type": "Pump",
      "in": "after_pipe_3",
      "out": "after_pump_2",
      "deltaP": 300000.0,
      "efficiency": 0.8
    },
    "pipe_4": {
      "type": "Pipes",
      "in": "after_pump_2",
      "out": "product",
      "delta_p": 1000.0,
      "diameter": 0.12
    }
  },
  "simulation": {
    "mode": "steady",
    "backend": "scipy"
  }
}

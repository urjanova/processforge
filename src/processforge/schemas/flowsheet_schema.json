{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProcessForge Flowsheet Configuration Schema",
  "type": "object",
  "required": [
    "streams",
    "units",
    "simulation"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "materials": {
      "type": "object",
      "description": "Named material definitions. Keys are component names referenced in stream z-fractions or used as structural materials.",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": ["friendly_material_id"],
          "properties": {
            "friendly_material_id": {
              "type": "integer",
              "description": "Unique numeric ID referenced by units to indicate what material they are made of"
            },
            "density": {
              "type": "number",
              "exclusiveMinimum": 0.0
            },
            "density_units": {
              "type": "string",
              "enum": ["g/cm3", "g/cc", "kg/m3", "atom/b-cm", "atom/cm3", "sum", "macro"]
            },
            "temperature": {
              "type": "number",
              "minimum": 0.0,
              "description": "Temperature in Kelvin"
            },
            "depletable": {
              "type": "boolean",
              "default": false
            },
            "nuclides": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["name", "percent", "percent_type"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Element symbol (e.g. 'C', 'Fe') or nuclide identifier (e.g. 'U235')"
                  },
                  "percent": {
                    "type": "number",
                    "exclusiveMinimum": 0.0
                  },
                  "percent_type": {
                    "type": "string",
                    "enum": ["ao", "wo"]
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      }
    },
    "material_mixes": {
      "type": "object",
      "description": "Named mixture definitions composed of materials from the materials section.",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": ["components"],
          "properties": {
            "percent_type": {
              "type": "string",
              "enum": ["ao", "wo", "vo"],
              "description": "Fraction type for OpenMC mix_materials: atom, weight, or volume fractions"
            },
            "components": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Key from the materials section"
                  },
                  "fraction": {
                    "type": "number",
                    "exclusiveMinimum": 0.0,
                    "maximum": 1.0
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      }
    },
    "streams": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": [
            "P",
            "T",
            "flowrate"
          ],
          "properties": {
            "P": {
              "type": "number",
              "minimum": 100.0
            },
            "T": {
              "type": "number",
              "minimum": 0.0
            },
            "flowrate": {
              "type": "number",
              "minimum": 0.0
            },
            "z": {
              "type": "object"
            }
          },
          "additionalProperties": true
        }
      }
    },
    "units": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": [
            "type",
            "in",
            "out",
            "material"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "Pump",
                "Valve",
                "Strainer",
                "Tank",
                "Pipes",
                "Flash",
                "Heater"
              ]
            },
            "in": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Single inlet stream name"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Multiple inlet stream names"
                }
              ]
            },
            "out": {
              "type": "string"
            },
            "deltaP": {
              "type": "number"
            },
            "efficiency": {
              "type": "number"
            },
            "pressure_ratio": {
              "type": "number"
            },
            "delta_p": {
              "type": "number"
            },
            "diameter": {
              "type": "number"
            },
            "volume": {
              "type": "number"
            },
            "initial_level": {
              "type": "number"
            },
            "material": {
              "type": "integer",
              "description": "friendly_material_id of the material this unit is made of"
            }
          },
          "additionalProperties": true
        }
      }
    },
    "simulation": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "steady",
            "dynamic"
          ]
        },
        "backend": {
          "type": "string",
          "enum": [
            "pyomo",
            "casadi",
            "scipy"
          ],
          "default": "pyomo",
          "description": "EO solver backend for steady-state mode"
        },
        "t0": {
          "type": "number",
          "description": "Start time for dynamic simulation"
        },
        "tf": {
          "type": "number",
          "description": "End time for dynamic simulation"
        },
        "dt": {
          "type": "number",
          "description": "Time step for dynamic simulation"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

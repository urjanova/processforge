{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Processforge Flowsheet Configuration Schema",
  "type": "object",
  "required": [
    "providers",
    "streams",
    "units",
    "simulation"
  ],
  "properties": {
    "providers": {
      "type": "object",
      "description": "Named provider declarations (Terraform-inspired). At least one provider must be specified.",
      "minProperties": 1,
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["coolprop", "cantera", "modelica", "festim", "openmc"],
              "description": "Provider engine type"
            },
            "mechanism": {
              "type": "string",
              "description": "Cantera mechanism file path (e.g. 'gri30.yaml')"
            },
            "phase": {
              "type": "string",
              "description": "Cantera phase name within the mechanism file"
            },
            "output_dir": {
              "type": "string",
              "description": "Provider output directory (Modelica/OpenMC/Festim)"
            },
            "cross_sections": {
              "type": "string",
              "description": "OpenMC provider: path to cross_sections.xml. Overrides OPENMC_CROSS_SECTIONS env var."
            }
          },
          "additionalProperties": true
        }
      }
    },
    "default_provider": {
      "type": "string",
      "description": "Name of the provider used by units that omit a 'provider' key. Defaults to built-in CoolProp."
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "materials": {
      "type": "object",
      "description": "Named material definitions. Keys are component names referenced in stream z-fractions or used as structural materials.",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": {
              "type": "integer",
              "description": "Unique numeric ID referenced by units to indicate what material they are made of"
            },
            "density": {
              "type": "number",
              "exclusiveMinimum": 0.0
            },
            "density_units": {
              "type": "string",
              "enum": ["g/cm3", "g/cc", "kg/m3", "atom/b-cm", "atom/cm3", "sum", "macro"]
            },
            "temperature": {
              "type": "number",
              "minimum": 0.0,
              "description": "Temperature in Kelvin"
            },
            "depletable": {
              "type": "boolean",
              "default": false
            },
            "D_0": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Pre-exponential diffusivity [m^2/s] — Festim hydrogen transport"
            },
            "E_D": {
              "type": "number",
              "minimum": 0,
              "description": "Diffusion activation energy [eV] — Festim hydrogen transport"
            },
            "S_0": {
              "type": "number",
              "exclusiveMinimum": 0,
              "description": "Pre-exponential Sieverts solubility [H/m^3/Pa^0.5] — Festim permeation"
            },
            "E_S": {
              "type": "number",
              "minimum": 0,
              "description": "Solubility activation energy [eV] — Festim permeation"
            },
            "thermal_cond": {
              "oneOf": [
                {"type": "number", "exclusiveMinimum": 0},
                {"type": "string", "description": "Python expression in T, e.g. '3 + 0.1 * T'"}
              ],
              "description": "Thermal conductivity [W/m/K] — constant or temperature-dependent expression"
            },
            "nuclides": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["name", "percent", "percent_type"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Element symbol (e.g. 'C', 'Fe') or nuclide identifier (e.g. 'U235')"
                  },
                  "percent": {
                    "type": "number",
                    "exclusiveMinimum": 0.0
                  },
                  "percent_type": {
                    "type": "string",
                    "enum": ["ao", "wo"]
                  }
                },
                "additionalProperties": false
              }
            },
            "elements": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["element", "percent", "percent_type"],
                "properties": {
                  "element": {
                    "type": "string",
                    "description": "Periodic table symbol, e.g. 'C', 'Fe', 'Ni'"
                  },
                  "percent": {
                    "type": "number",
                    "exclusiveMinimum": 0.0
                  },
                  "percent_type": {
                    "type": "string",
                    "enum": ["ao", "wo"]
                  }
                },
                "additionalProperties": false
              },
              "description": "Element-fraction entries for openmc.Material.add_element() calls"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "material_mixes": {
      "type": "object",
      "description": "Named mixture definitions composed of materials from the materials section.",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": ["friendly_material_mix_id", "components"],
          "properties": {
            "friendly_material_mix_id": {
              "type": "integer",
              "description": "Unique numeric ID for this material mix"
            },
            "percent_type": {
              "type": "string",
              "enum": ["ao", "wo", "vo"],
              "description": "Fraction type for OpenMC mix_materials: atom, weight, or volume fractions"
            },
            "components": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Key from the materials section"
                  },
                  "fraction": {
                    "type": "number",
                    "exclusiveMinimum": 0.0,
                    "maximum": 1.0
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      }
    },
    "streams": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": [
            "P",
            "T",
            "flowrate"
          ],
          "properties": {
            "P": {
              "type": "number",
              "minimum": 100.0
            },
            "T": {
              "type": "number",
              "minimum": 0.0
            },
            "flowrate": {
              "type": "number",
              "minimum": 0.0
            },
            "z": {
              "type": "object"
            },
            "material_mix": {
              "type": "integer",
              "description": "friendly_material_mix_id of the material mix carried by this stream"
            }
          },
          "additionalProperties": true
        }
      }
    },
    "units": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": [
            "type",
            "material"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "Pump",
                "Valve",
                "Strainer",
                "Tank",
                "Pipes",
                "Flash",
                "Heater",
                "CSTR",
                "PFR",
                "IdealGasReactor",
                "FestimMembrane",
                "SolverUnit"
              ]
            },
            "provider": {
              "type": "string",
              "description": "Name of a declared provider to use for this unit. Omit to use the flowsheet default (CoolProp)."
            },
            "in": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Single inlet stream name"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Multiple inlet stream names"
                }
              ]
            },
            "out": {
              "type": "string"
            },
            "deltaP": {
              "type": "number"
            },
            "efficiency": {
              "type": "number"
            },
            "pressure_ratio": {
              "type": "number"
            },
            "delta_p": {
              "type": "number"
            },
            "diameter": {
              "type": "number"
            },
            "volume": {
              "type": "number"
            },
            "initial_level": {
              "type": "number"
            },
            "material": {
              "type": "integer",
              "description": "id of the material this unit is made of"
            }
          },
          "additionalProperties": true,
          "allOf": [
            {
              "if": {
                "properties": { "type": { "const": "FestimMembrane" } }
              },
              "then": {
                "required": ["in", "retentate_out", "permeate_out", "thickness", "mesh_cells"],
                "properties": {
                  "in": { "type": "string" },
                  "retentate_out": { "type": "string" },
                  "permeate_out": { "type": "string" },
                  "thickness": { "type": "number", "minimum": 0 },
                  "mesh_cells": { "type": "integer", "minimum": 1 }
                }
              }
            },
            {
              "if": {
                "properties": { "type": { "const": "SolverUnit" } }
              },
              "then": {
                "required": ["sim_type"],
                "properties": {
                  "sim_type": {
                    "type": "string",
                    "description": "Provider-interpreted simulation mode (e.g. 'heat_2d', 'eigenvalue')"
                  },
                  "solver_config": {
                    "type": "object",
                    "description": "Provider-specific settings — opaque to the framework (mesh, BCs, traps, exports, …)"
                  }
                }
              }
            },
            {
              "if": {
                "not": {
                  "properties": {
                    "type": { "enum": ["FestimMembrane", "SolverUnit"] }
                  }
                }
              },
              "then": {
                "required": ["in", "out"]
              }
            }
          ]
        }
      }
    },
    "simulation": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "steady",
            "dynamic"
          ]
        },
        "backend": {
          "type": "string",
          "enum": [
            "pyomo",
            "casadi",
            "scipy"
          ],
          "description": "EO solver backend for steady-state mode. Overrides default_backend."
        },
        "default_backend": {
          "type": "string",
          "enum": [
            "pyomo",
            "casadi",
            "scipy"
          ],
          "default": "scipy",
          "description": "EO solver backend used when 'backend' is omitted. Defaults to 'scipy'."
        },
        "t0": {
          "type": "number",
          "description": "Start time for dynamic simulation"
        },
        "tf": {
          "type": "number",
          "description": "End time for dynamic simulation"
        },
        "dt": {
          "type": "number",
          "description": "Time step for dynamic simulation"
        },
        "convergence_signal": {
          "type": "object",
          "description": "Provider-specific convergence signal for homotopy fallback. Defaults to k_eff for OpenMC, flux for FESTIM.",
          "properties": {
            "signal_key": {
              "type": "string",
              "description": "Scalar key to monitor for convergence (e.g. 'k_eff', 'flux', 'temperature')"
            },
            "target": {
              "type": "number",
              "description": "Target value to approach (e.g. 1.0 for k_eff)"
            },
            "tolerance": {
              "type": "number",
              "default": 0.01,
              "description": "Acceptance tolerance relative to target"
            },
            "provider": {
              "type": "string",
              "enum": ["openmc", "festim"],
              "description": "Provider to apply this signal to. If omitted, applies to all providers."
            }
          },
          "required": ["signal_key", "target"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

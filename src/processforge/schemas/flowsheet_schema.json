{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProcessForge Flowsheet Configuration Schema",
  "type": "object",
  "required": [
    "streams",
    "units",
    "simulation"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "streams": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": [
            "P",
            "T",
            "flowrate"
          ],
          "properties": {
            "P": {
              "type": "number",
              "minimum": 100.0
            },
            "T": {
              "type": "number",
              "minimum": 0.0
            },
            "flowrate": {
              "type": "number",
              "minimum": 0.0
            },
            "z": {
              "type": "object"
            }
          },
          "additionalProperties": true
        }
      }
    },
    "units": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "required": [
            "type",
            "in",
            "out"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "Pump",
                "Valve",
                "Strainer",
                "Tank",
                "Pipes",
                "Flash",
                "Heater"
              ]
            },
            "in": {
              "oneOf": [
                {
                  "type": "string",
                  "description": "Single inlet stream name"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Multiple inlet stream names"
                }
              ]
            },
            "out": {
              "type": "string"
            },
            "deltaP": {
              "type": "number"
            },
            "efficiency": {
              "type": "number"
            },
            "pressure_ratio": {
              "type": "number"
            },
            "delta_p": {
              "type": "number"
            },
            "diameter": {
              "type": "number"
            },
            "volume": {
              "type": "number"
            },
            "initial_level": {
              "type": "number"
            }
          },
          "additionalProperties": true
        }
      }
    },
    "simulation": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "steady",
            "dynamic"
          ]
        },
        "backend": {
          "type": "string",
          "enum": [
            "pyomo",
            "casadi",
            "scipy"
          ],
          "default": "pyomo",
          "description": "EO solver backend for steady-state mode"
        },
        "t0": {
          "type": "number",
          "description": "Start time for dynamic simulation"
        },
        "tf": {
          "type": "number",
          "description": "End time for dynamic simulation"
        },
        "dt": {
          "type": "number",
          "description": "Time step for dynamic simulation"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
